# MLBB -> TikTok Auto Clipper (.env example)
# Copy to .env, then fill values.

# =====================
# Core AI Configuration
# =====================
SUMOPOD_API_KEY=
SUMOPOD_BASE_URL=https://ai.sumopod.com/v1
LLM_MODEL=gpt-4o-mini
WHISPER_MODEL=whisper-1
WHISPER_API_ENABLED=1
WHISPER_LOCAL_FALLBACK=1

# =====================
# Pipeline Inputs/Tools
# =====================
OUTPUT_ROOT=outputs
FFMPEG_BIN=ffmpeg
YT_DLP_BIN=yt-dlp
COOKIES_PATH=cookies.txt
EVENT_IMAGE_PATH=assets/event_banner.jpg

# =====================
# Layout (1080x1920)
# =====================
TOP_BANNER_PX=240
BOT_BANNER_PX=240
# Optional explicit split override. Leave 0 for auto ratio.
GAMEPLAY_HEIGHT_PX=0
FACE_HEIGHT_PX=0

# =====================
# Candidate Detection
# =====================
FACE_ROI_SCAN_SECONDS=60
FACE_MODE_AUTO=1
MULTICAM_MIN_FACES=3
MULTICAM_AREA_RATIO_MAX=2.5
MULTICAM_YVAR_MAX=0.0025
OCR_LANG=eng
OCR_SAMPLE_FPS=1.0
OCR_AUTO_SCAN_SECONDS=60

# Optional normalized ROI presets (x1,y1,x2,y2) for MLBB HUD
# OCR_ROI_ANNOUNCEMENT=0.20,0.02,0.80,0.18
# OCR_ROI_KILL_FEED=0.65,0.02,0.98,0.28
OCR_ROI_ANNOUNCEMENT=
OCR_ROI_KILL_FEED=

# =====================
# Clip Selection
# =====================
CLIP_COUNT=5
CLIP_MIN_SEC=20
CLIP_MAX_SEC=45
HASHTAGS="#MLBBGoldenMonth #MLBBGoldenTurtle #mlbb #mobilelegends"
TIKTOK_MENTION=

# =====================
# TikTok Upload (Optional)
# =====================
TIKTOK_UPLOAD_ENABLED=0
TIKTOK_MODE=sandbox
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# Optional if you already have valid OAuth tokens
TIKTOK_ACCESS_TOKEN=
TIKTOK_REFRESH_TOKEN=
TIKTOK_TOKEN_EXPIRES_AT=0

# If enabled, CLI will open browser OAuth flow when no token exists.
TIKTOK_AUTO_AUTH=0

# TikTok post options
TIKTOK_PRIVACY_LEVEL=SELF_ONLY
TIKTOK_DISABLE_DUET=0
TIKTOK_DISABLE_COMMENT=0
TIKTOK_DISABLE_STITCH=0
